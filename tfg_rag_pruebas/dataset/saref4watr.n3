s4watr:Ocean a owl:Class ;
    rdfs:label "Ocean"@en ;
    rdfs:comment "An ocean is a large body of salt water."@en ;
    rdfs:subClassOf s4watr:SinkAsset .

s4watr:Odour a owl:NamedIndividual,
        s4watr:AcceptabilityProperty ;
